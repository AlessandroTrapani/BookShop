<?xml version="1.0" encoding="UTF-8"?>
<Context>

    <!--
        DataSource del progetto Bookshop.
        Verrà recuperato tramite JNDI dalla classe ConnessioneDatabase.
    -->
    <Resource
        name="jdbc/bookshop"
        auth="Container"
        type="javax.sql.DataSource"
        maxTotal="20"
        maxIdle="10"
        maxWaitMillis="-1"
        username="root"
        password="root"
        driverClassName="com.mysql.cj.jdbc.Driver"
        url="jdbc:mysql://localhost:3306/bookshop?useSSL=false&amp;serverTimezone=UTC" />

</Context>